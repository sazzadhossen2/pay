    "/api/subscription/calculate-price": {
      "post": {
        "tags": ["📋 Subscription"],
        "summary": "Price Preview (Calculate before payment)",
        "description": "Payment করার আগে price calculate করো।\nFormula: `units × pricePerUnit × months`\nYearly plan এ 20% discount আছে।",
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": { "$ref": "#/components/schemas/CalculatePriceRequest" },
              "examples": {
                "self_managed_3m": {
                  "summary": "Self Managed — 3 Months, 2 units",
                  "value": { "planType": "self_managed", "planKey": "3m", "units": 2 }
                },
                "company_managed_1y": {
                  "summary": "Company Managed — Yearly, 5 units",
                  "value": { "planType": "company_managed", "planKey": "1y", "units": 5 }
                }
              }
            }
          }
        },
        "responses": {
          "200": {
            "description": "✅ Price calculation",
            "content": {
              "application/json": {
                "example": {
                  "success": true,
                  "data": {
                    "planType": "self_managed",
                    "planLabel": "3 Months",
                    "planKey": "3m",
                    "units": 2,
                    "pricePerUnit": 200,
                    "totalPrice": 1200,
                    "currency": "BDT",
                    "breakdown": "2 units × ৳200 × 3 months = ৳1,200",
                    "startDate": "2026-03-09T00:00:00.000Z",
                    "endDate": "2026-06-09T00:00:00.000Z"
                  }
                }
              }
            }
          },
          "400": {
            "description": "❌ Missing or invalid fields",
            "content": {
              "application/json": {
                "examples": {
                  "missing": {
                    "summary": "Missing fields",
                    "value": { "success": false, "message": "Missing required fields: planType, planKey, units" }
                  },
                  "invalid_plan": {
                    "summary": "Invalid planType",
                    "value": { "success": false, "message": "Invalid planType. Must be 'self_managed' or 'company_managed'" }
                  }
                }
              }
            }
          }
        }
      }
    },
    "/api/subscription/check-validity": {
      "post": {
        "tags": ["📋 Subscription"],
        "summary": "Subscription Valid কিনা চেক করো",
        "description": "User এর subscription valid কিনা চেক করো।\n\n**Logic:** `isActive && !isExpired && paymentStatus == 'completed'`\n\nExpired subscription থাকলে auto-deactivate করে।",
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": { "$ref": "#/components/schemas/CheckValidityRequest" },
              "example": { "userId": "firebase_user_uid_123" }
            }
          }
        },
        "responses": {
          "200": {
            "description": "Validity result",
            "content": {
              "application/json": {
                "examples": {
                  "valid": {
                    "summary": "✅ Valid subscription",
                    "value": {
                      "success": true,
                      "isValid": true,
                      "isActive": true,
                      "isExpired": false,
                      "paymentStatus": "completed",
                      "daysRemaining": 89,
                      "planType": "self_managed",
                      "planLabel": "3 Months"
                    }
                  },
                  "expired": {
                    "summary": "⏰ Expired subscription",
                    "value": {
                      "success": true,
                      "isValid": false,
                      "isActive": false,
                      "isExpired": true,
                      "paymentStatus": "completed",
                      "daysRemaining": 0,
                      "planType": "self_managed",
                      "planLabel": "3 Months"
                    }
                  },
                  "none": {
                    "summary": "❌ No subscription at all",
                    "value": {
                      "success": true,
                      "isValid": false,
                      "isActive": false,
                      "isExpired": true,
                      "paymentStatus": null,
                      "daysRemaining": 0,
                      "planType": null,
                      "planLabel": null
                    }
                  }
                }
              }
            }
          },
          "400": {
            "description": "❌ userId missing",
            "content": {
              "application/json": {
                "example": { "success": false, "message": "userId is required" }
              }
            }
          }
        }
      }
    },
    "/api/payment/success": {
      "post": {
        "tags": ["🔒 SSLCommerz Callbacks"],
        "summary": "🔒 Success Callback (SSLCommerz auto-calls this)",
        "description": "⚠️ **Flutter থেকে call করার দরকার নেই।**\n\nSSLCommerz payment success হলে এই endpoint এ POST করে।\n\n**Server যা করে:**\n1. Transaction validate করে SSLCommerz API দিয়ে\n2. User এর পুরানো active subscription deactivate করে\n3. নতুন subscription activate করে (`isActive: true`, `paymentStatus: completed`)\n4. `clientSuccessUrl` থাকলে সেখানে redirect করে, না থাকলে `/payment-result` page এ redirect করে\n\n**Redirect URL format:**\n`{success_url}?status=success&tran_id=SSL_xxx&subscription_id=yyy`",
        "requestBody": {
          "required": true,
          "content": {
            "application/x-www-form-urlencoded": {
              "schema": {
                "type": "object",
                "properties": {
                  "tran_id": { "type": "string", "description": "Transaction ID" },
                  "val_id": { "type": "string", "description": "Validation ID" },
                  "amount": { "type": "string", "description": "Paid amount" },
                  "card_type": { "type": "string", "description": "Payment method (bKash, Nagad, VISA, etc.)" },
                  "card_issuer": { "type": "string", "description": "Card issuer" },
                  "bank_tran_id": { "type": "string", "description": "Bank transaction ID" },
                  "status": { "type": "string", "description": "VALID / VALIDATED" }
                }
              }
            }
          }
        },
        "responses": {
          "303": {
            "description": "Redirects to `clientSuccessUrl` or `/payment-result?status=success`"
          }
        }
      }
    },
    "/api/payment/fail": {
      "post": {
        "tags": ["🔒 SSLCommerz Callbacks"],
        "summary": "🔒 Fail Callback (SSLCommerz auto-calls this)",
        "description": "⚠️ **Flutter থেকে call করার দরকার নেই।**\n\nSSLCommerz payment fail হলে এই endpoint এ POST করে।\n\n**Server যা করে:**\n1. Subscription `paymentStatus` = `'failed'` করে\n2. `clientFailUrl` থাকলে সেখানে redirect করে\n\n**Redirect URL format:**\n`{fail_url}?status=fail&tran_id=SSL_xxx`",
        "requestBody": {
          "required": true,
          "content": {
            "application/x-www-form-urlencoded": {
              "schema": {
                "type": "object",
                "properties": {
                  "tran_id": { "type": "string", "description": "Transaction ID" }
                }
              }
            }
          }
        },
        "responses": {
          "303": {
            "description": "Redirects to `clientFailUrl` or `/payment-result?status=fail`"
          }
        }
      }
    },
    "/api/payment/cancel": {
      "post": {
        "tags": ["🔒 SSLCommerz Callbacks"],
        "summary": "🔒 Cancel Callback (SSLCommerz auto-calls this)",
        "description": "⚠️ **Flutter থেকে call করার দরকার নেই।**\n\nUser payment cancel করলে SSLCommerz এই endpoint এ POST করে।\n\n**Server যা করে:**\n1. Subscription `paymentStatus` = `'cancelled'` করে\n2. `clientCancelUrl` থাকলে সেখানে redirect করে\n\n**Redirect URL format:**\n`{cancel_url}?status=cancelled&tran_id=SSL_xxx`",
        "requestBody": {
          "required": true,
          "content": {
            "application/x-www-form-urlencoded": {
              "schema": {
                "type": "object",
                "properties": {
                  "tran_id": { "type": "string", "description": "Transaction ID" }
                }
              }
            }
          }
        },
        "responses": {
          "303": {
            "description": "Redirects to `clientCancelUrl` or `/payment-result?status=cancelled`"
          }
        }
      }
    },
    "/api/payment/ipn": {
      "post": {
        "tags": ["🔒 SSLCommerz Callbacks"],
        "summary": "🔒 IPN — Instant Payment Notification (server-to-server)",
        "description": "⚠️ **Flutter থেকে call করার দরকার নেই।**\n\nSSLCommerz server-to-server notification পাঠায়।\nDual activation path — success callback এর পাশাপাশি IPN ও subscription activate করতে পারে (reliability এর জন্য)।\n\n**Server যা করে:**\n1. Transaction validate করে SSLCommerz API দিয়ে\n2. Valid হলে subscription activate করে\n3. Invalid হলে `paymentStatus = 'failed'` করে",
        "requestBody": {
          "required": true,
          "content": {
            "application/x-www-form-urlencoded": {
              "schema": {
                "type": "object",
                "properties": {
                  "tran_id": { "type": "string", "description": "Transaction ID" },
                  "val_id": { "type": "string", "description": "Validation ID" },
                  "status": { "type": "string", "description": "VALID / VALIDATED / FAILED" }
                }
              }
            }
          }
        },
        "responses": {
          "200": {
            "description": "IPN acknowledged",
            "content": {
              "application/json": {
                "example": { "message": "IPN received" }
              }
            }
          },
          "404": {
            "description": "Transaction not found",
            "content": {
              "application/json": {
                "example": { "message": "Transaction not found" }
              }
            }
          }
        }
      }
    },
    "/payment-result": {
      "get": {
        "tags": ["📄 Pages"],
        "summary": "Payment Result HTML Page",
        "description": "Server-rendered HTML page যেটা payment শেষে দেখায়।\nFlutter WebView এই URL detect করে navigate করে।\n\n**Query params:**\n- `status` = `success` | `fail` | `cancelled`\n- `tran_id` = Transaction ID\n- `subscription_id` = MongoDB Subscription ID (only on success)\n\n**Note:** এই page শুধু তখনই দেখায় যখন `success_url`/`fail_url`/`cancel_url` pass করা হয়নি।",
        "parameters": [
          {
            "name": "status",
            "in": "query",
            "required": false,
            "description": "Payment result status",
            "schema": { "type": "string", "enum": ["success", "fail", "cancelled"] },
            "example": "success"
          },
          {
            "name": "tran_id",
            "in": "query",
            "required": false,
            "description": "Transaction ID",
            "schema": { "type": "string" },
            "example": "SSL_firebase_user_uid_123_1740307200000"
          },
          {
            "name": "subscription_id",
            "in": "query",
            "required": false,
            "description": "MongoDB Subscription ID (only on success)",
            "schema": { "type": "string" },
            "example": "65f1a2b3c4d5e6f7a8b9c0d1"
          }
        ],
        "responses": {
          "200": {
            "description": "HTML page with payment result (success/fail/cancelled)",
            "content": {
              "text/html": {
                "example": "<!DOCTYPE html><html>... Payment Result Page ...</html>"
              }
            }
          }
        }
      }
    }
  },
  "components": {
    "schemas": {
      "PaymentInitRequest": {
        "type": "object",
        "required": ["userId", "customerName", "customerEmail", "customerPhone", "planType", "planKey", "units"],
        "properties": {
          "userId": { "type": "string", "description": "Firebase UID", "example": "firebase_user_uid_123" },
          "customerName": { "type": "string", "description": "Customer name", "example": "Sazzad" },
          "customerEmail": { "type": "string", "format": "email", "description": "Email", "example": "sazzad@example.com" },
          "customerPhone": { "type": "string", "description": "Phone number", "example": "01700000000" },
          "customerAddress": { "type": "string", "description": "Address (optional, default: Dhaka)", "example": "Dhaka, Bangladesh" },
          "planType": { "type": "string", "enum": ["self_managed", "company_managed"], "description": "self_managed (৳200/unit) or company_managed (৳1500/unit)" },
          "planKey": { "type": "string", "enum": ["3m", "6m", "1y"], "description": "3m = 3 Months, 6m = 6 Months, 1y = Yearly (20% off)" },
          "units": { "type": "integer", "minimum": 1, "description": "Number of units", "example": 2 },
          "success_url": { "type": "string", "description": "🔄 Dynamic redirect URL after successful payment (Flutter WebView detect করবে)", "example": "https://yourapp.com/payment/success" },
          "fail_url": { "type": "string", "description": "🔄 Dynamic redirect URL after failed payment", "example": "https://yourapp.com/payment/fail" },
          "cancel_url": { "type": "string", "description": "🔄 Dynamic redirect URL after cancelled payment", "example": "https://yourapp.com/payment/cancel" }
        }
      },
      "CalculatePriceRequest": {
        "type": "object",
        "required": ["planType", "planKey", "units"],
        "properties": {
          "planType": { "type": "string", "enum": ["self_managed", "company_managed"], "description": "Plan type" },
          "planKey": { "type": "string", "enum": ["3m", "6m", "1y"], "description": "Duration key" },
          "units": { "type": "integer", "minimum": 1, "description": "Number of units", "example": 2 }
        }
      },
      "CheckValidityRequest": {
        "type": "object",
        "required": ["userId"],
        "properties": {
          "userId": { "type": "string", "description": "Firebase UID", "example": "firebase_user_uid_123" }
        }
      }
    }
  }
}
